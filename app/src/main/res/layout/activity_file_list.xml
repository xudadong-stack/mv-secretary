<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/colorPrimaryDark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@null"
            android:contentDescription="Back"
            android:src="@drawable/ic_arrow_left"
            android:tint="@color/text_secondary" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Export button (shown when items selected) -->
        <ImageButton
            android:id="@+id/btn_export"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@null"
            android:contentDescription="Export"
            android:src="@drawable/ic_export"
            android:tint="@color/accent_green"
            android:visibility="gone" />

        <!-- Move button (shown when items selected) -->
        <ImageButton
            android:id="@+id/btn_move"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@null"
            android:contentDescription="Move"
            android:src="@drawable/ic_move"
            android:tint="@color/accent_blue"
            android:visibility="gone" />

        <!-- Delete button (shown in selection mode) -->
        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@null"
            android:contentDescription="Delete"
            android:src="@drawable/ic_delete"
            android:tint="@color/accent_red"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/btn_new_folder"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@null"
            android:contentDescription="New Folder"
            android:src="@drawable/ic_folder_add"
            android:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/btn_import"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@null"
            android:contentDescription="Import"
            android:src="@drawable/ic_upload"
            android:tint="@color/text_secondary" />
    </LinearLayout>

    <!-- Selection info bar (shown in selection mode) -->
    <LinearLayout
        android:id="@+id/selection_bar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@color/colorPrimary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <TextView
            android:id="@+id/tv_selection_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <ImageButton
            android:id="@+id/btn_selection_cancel"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@null"
            android:contentDescription="Cancel"
            android:src="@drawable/ic_close"
            android:tint="@color/text_secondary" />
    </LinearLayout>

    <!-- Folder path indicator -->
    <TextView
        android:id="@+id/tv_path"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="@color/colorPrimary"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/selection_bar" />

    <!-- Folder grid section -->
    <TextView
        android:id="@+id/tv_folder_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:text="@string/folder_header"
        android:textColor="@color/text_hint"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_path" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_folders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_folder_header" />

    <!-- Files section -->
    <TextView
        android:id="@+id/tv_files_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:text="@string/files_header"
        android:textColor="@color/text_hint"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/recycler_folders" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_files"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_files_header" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="64dp"
        android:text="@string/main_no_files"
        android:textColor="@color/text_hint"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_files_header" />

</androidx.constraintlayout.widget.ConstraintLayout>
