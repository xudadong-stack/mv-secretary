<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/com_nj"
    tools:context=".activity.ToSetupActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp">
        <TextView android:id="@+id/panyName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:gravity="center_vertical"
            android:paddingLeft="10dp"
            android:textSize="14sp"
            android:textColor="@color/black"/>

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="50dp"
        android:text="设置密码"
        android:gravity="center"
        android:textColor="@color/white"
        android:background="@color/blue"
        android:textSize="28dp"/>

    <EditText
        android:id="@+id/adminPass"
        android:layout_height="43dp"
        android:layout_width="match_parent"
        android:layout_marginTop="130dp"
        android:layout_marginLeft="15dp"
        android:layout_marginRight="15dp"
        android:paddingLeft="10dp"
        android:hint="输入管理密码"
        android:background="@drawable/bg_edittext_border"
        android:inputType="textPassword"/>

    <Button
        android:id="@+id/butok"
        android:layout_height="45dp"
        android:layout_width="match_parent"
        android:layout_marginTop="210dp"
        android:layout_marginLeft="25dp"
        android:layout_marginRight="25dp"
        android:textSize="20dp"
        android:text="确认"
        android:background="@drawable/buton_yes_col_red_fillet"
        android:textColor="@android:color/white"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">
        <TextView android:id="@+id/serviceName"
            android:layout_width="match_parent"
            android:layout_height="25dp"
            android:gravity="center"
            android:textSize="10dp"
            android:textColor="@color/back"/>

        <TextView android:id="@+id/servicePhone"
            android:layout_width="match_parent"
            android:layout_height="25dp"
            android:gravity="center"
            android:textSize="10dp"
            android:textColor="@color/back"/>
    </LinearLayout>

</RelativeLayout>