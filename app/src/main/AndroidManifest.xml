<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.secretary">

    <uses-sdk tools:overrideLibrary="androidx.security" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <!-- 优量汇 SDK 在 Android 12+ (API 31+) 需要广告 ID 权限 -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID"/>

    <application
        android:name=".MyApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Main Activity (default launcher) -->
        <activity android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Lock Activity -->
        <activity android:name=".ui.LockActivity"
            android:exported="false"/>

        <!-- Main File List Activity -->
        <activity android:name=".ui.MainActivity"
            android:exported="false" />

        <!-- Image Preview Activity -->
        <activity android:name=".ui.ImagePreviewActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize" />

        <!-- Video Player Activity -->
        <activity android:name=".ui.VideoPlayerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize" />

        <!-- File List Activity (per-category) -->
        <activity android:name=".ui.FileListActivity"
            android:exported="false"/>

        <!-- Settings Activity -->
        <activity android:name=".ui.SettingsActivity"
            android:exported="false" />

        <!-- ============================================= -->
        <!-- Disguise Activities (launched by aliases)      -->
        <!-- ============================================= -->

        <!-- Fake Calculator -->
        <activity android:name=".ui.FakeCalculatorActivity"
            android:exported="true"
            android:theme="@style/Theme.Disguise" />

        <!-- Fake Calendar -->
        <activity android:name=".ui.FakeCalendarActivity"
            android:exported="true"
            android:theme="@style/Theme.Disguise" />

        <!-- ============================================= -->
        <!-- Icon Disguise Activity Aliases                 -->
        <!-- ============================================= -->

        <!-- Calculator disguise: opens a real calculator UI -->
        <activity-alias
            android:name=".FakeCalculator"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_calculator"
            android:label="@string/app_name_calculator"
            android:targetActivity=".ui.FakeCalculatorActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Calendar disguise: opens a real calendar UI -->
        <activity-alias
            android:name=".FakeCalendar"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_calendar"
            android:label="@string/app_name_calendar"
            android:targetActivity=".ui.FakeCalendarActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

    </application>

</manifest>
